{
  "project_id": "maa-bbb",
  "display_name": "Maa_bbb Android Sample",
  "default_resource_id": "官服",
  "default_task_id": "崩坏三 启动！",
  "supported_controllers": [
    "adb",
    "安卓端"
  ],
  "attach_resource_paths": [],
  "github_resource_repository": {
    "owner": "miaojiuqing",
    "repo": "Maa_bbb",
    "branch": "main",
    "asset_root_path": ".",
    "required_paths": [
      "interface.json",
      "resource",
      "agent/main.py",
      "requirements.txt",
      "resource/base/model/detect",
      "resource/base/model/ocr"
    ],
    "submodules": [
      {
        "api_path": "assets/MaaCommonAssets",
        "target_path": "assets/MaaCommonAssets",
        "fallback_git_url": "https://github.com/MaaXYZ/MaaCommonAssets.git"
      }
    ],
    "copy_mappings": [
      {
        "from": "assets/interface.json",
        "to": "interface.json"
      },
      {
        "from": "assets/resource",
        "to": "resource"
      },
      {
        "from": "assets/custom",
        "to": "custom"
      },
      {
        "from": "assets/MaaCommonAssets/OCR/ppocr_v5/zh_cn",
        "to": "resource/base/model/ocr"
      }
    ]
  },
  "resource_package_names": {
    "官服": "com.miHoYo.enterprise.NGHSoD",
    "B服": "com.miHoYo.bh3.bilibili",
    "OPPO渠道服": "com.miHoYo.bh3.nearme.gamecenter",
    "华为渠道服": "com.miHoYo.bh3.huawei",
    "应用宝渠道服": "com.tencent.tmgp.bh3",
    "VIVO服": "com.miHoYo.bh3.vivo",
    "九游服": "com.miHoYo.bh3.uc",
    "小米服": "com.miHoYo.bh3.mi"
  }
}
